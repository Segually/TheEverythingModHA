# ─── Build output ────────────────────────────────────────────────
[Bb]in/
[Oo]bj/

# ─── IDE / editor ────────────────────────────────────────────────
.vs/
.idea/
*.user
*.suo
*.userosscache
*.sln.docstates

# ─── NuGet ───────────────────────────────────────────────────────
# Packages are restored from the feeds in nuget.config; the local
# ./packages cache is not committed.
packages/
*.nupkg

# ─── Unity AssetBundle build metadata ────────────────────────────
# The bundles themselves are embedded resources and ARE committed.
# Their .manifest sidecars are Unity build artifacts and are not.
*.manifest

# ─── Python tooling cache ────────────────────────────────────────
__pycache__/
*.pyc

# ─── Local agent / tooling config ────────────────────────────────
.claude/

# ─── OS cruft ────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
.DS_Store
